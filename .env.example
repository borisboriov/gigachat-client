# GigaChat API credentials
# Получить на: https://developers.sber.ru/portal/products/gigachat
#
# Скопируй этот файл в .env.local и заполни реальными значениями:
#   cp .env.example .env.local
#
# ВНИМАНИЕ: .env.local добавлен в .gitignore — никогда не коммить реальные ключи!

VITE_GIGACHAT_CLIENT_ID=your_client_id_here
VITE_GIGACHAT_CLIENT_SECRET=your_client_secret_here

# Опционально — модель по умолчанию
# VITE_GIGACHAT_MODEL=GigaChat
