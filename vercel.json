{
  "rewrites": [
    {
      "source": "/api/oauth",
      "destination": "https://ngw.devices.sberbank.ru:9443/api/v2/oauth"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://gigachat.devices.sberbank.ru/api/v1/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
